<!DOCTYPE html>
<html lang="en" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="x-apple-disable-message-reformatting">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="color-scheme" content="light">
    <meta name="supported-color-schemes" content="light">
    <title>Verification Code - Portfolio Admin</title>
    <!--[if mso]>
    <style>
        * { font-family: sans-serif !important; }
    </style>
    <![endif]-->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Bakbak+One&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Orbitron:wght@400..900&family=Space+Grotesk:wght@300..700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            color-scheme: light;
            supported-color-schemes: light;
        }

        body {
            background-color: #000000 !important;
            margin: 0;
            padding: 0;
            width: 100% !important;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
            font-family: 'Space Grotesk', 'Helvetica Neue', Helvetica, Arial, sans-serif;
            color: #ffffff;
        }

        table {
            border-spacing: 0;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        .wrapper {
            width: 100%;
            background-color: #000000 !important;
            table-layout: fixed;
        }

        .main-container {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
            background-color: #000000 !important;
        }

        .inner-content {
            background-color: #0a0a0a !important;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.1);
            margin: 40px 20px;
            position: relative;
        }

        /* Top accent bar */
        .accent-bar {
            width: 100%;
            height: 3px;
            background-color: #ffffff;
        }

        .header {
            text-align: left;
            padding: 48px 50px 32px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .header-eyebrow {
            font-family: 'Orbitron', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.35) !important;
            margin: 0 0 18px 0;
        }

        .header h1 {
            font-family: 'Orbitron', sans-serif;
            color: #ffffff !important;
            font-size: 36px;
            margin: 0;
            font-weight: 900;
            letter-spacing: -0.5px;
            line-height: 1.1;
            text-transform: uppercase;
        }

        .header-sub {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.4) !important;
            margin: 12px 0 0 0;
            font-weight: 400;
        }

        .divider {
            width: 40px;
            height: 2px;
            background-color: #ffffff !important;
            margin: 0 50px;
            opacity: 1;
        }

        .body-content {
            padding: 48px 50px;
        }

        .body-content h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.5) !important;
            margin: 0 0 20px;
        }

        .message {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 16px;
            line-height: 1.8;
            color: rgba(255, 255, 255, 0.65) !important;
            margin-bottom: 40px;
            font-weight: 400;
        }

        .otp-box {
            background-color: #111111 !important;
            padding: 36px 30px;
            display: block;
            margin: 0 0 40px 0;
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-left: 3px solid #ffffff;
        }

        .otp-label {
            font-family: 'Orbitron', sans-serif;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 4px;
            color: rgba(255, 255, 255, 0.35) !important;
            margin: 0 0 16px 0;
            font-weight: 700;
            display: block;
        }

        .otp-code {
            font-family: 'Orbitron', sans-serif;
            font-size: 52px;
            font-weight: 900;
            letter-spacing: 10px;
            color: #ffffff !important;
            margin: 0;
            line-height: 1;
        }

        .otp-expiry {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.3) !important;
            margin: 14px 0 0 0;
            letter-spacing: 0.5px;
        }

        .warning-block {
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            padding-top: 28px;
        }

        .warning-block p {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 13px;
            line-height: 1.7;
            color: rgba(255, 255, 255, 0.35) !important;
            margin: 0;
        }

        .footer {
            text-align: left;
            padding: 28px 50px;
            background-color: #000000 !important;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
        }

        .footer-brand {
            font-family: 'Orbitron', sans-serif;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.6) !important;
            margin: 0 0 6px 0;
        }

        .footer p {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.2) !important;
            margin: 4px 0;
        }

        /* Force light content on dark – override dark mode email clients trying to invert */
        @media (prefers-color-scheme: dark) {
            body,
            .wrapper,
            .main-container {
                background-color: #000000 !important;
            }

            .inner-content {
                background-color: #0a0a0a !important;
            }

            .otp-box {
                background-color: #111111 !important;
            }

            .footer {
                background-color: #000000 !important;
            }

            h1,
            .otp-code {
                color: #ffffff !important;
            }
        }

        /* Mobile */
        @media only screen and (max-width: 600px) {
            .inner-content {
                margin: 16px 12px !important;
            }

            .header {
                padding: 36px 28px 28px !important;
            }

            .header h1 {
                font-size: 26px !important;
            }

            .divider {
                margin: 0 28px !important;
            }

            .body-content {
                padding: 36px 28px !important;
            }

            .otp-code {
                font-size: 38px !important;
                letter-spacing: 6px !important;
            }

            .footer {
                padding: 24px 28px !important;
            }
        }
    </style>
</head>

<body style="background-color: #000000;">
    <center class="wrapper">
        <div class="main-container">
            <div class="inner-content">

                <!-- Top accent line -->
                <div class="accent-bar"></div>

                <!-- Header -->
                <div class="header">
                    <p class="header-eyebrow">Portfolio Admin Panel</p>
                    <h1>Access<br>Verification</h1>
                    <p class="header-sub">Identity confirmation required to proceed.</p>
                </div>

                <div class="divider" style="margin-top: 36px; margin-bottom: 0;"></div>

                <!-- Main Body -->
                <div class="body-content">
                    <h2>One-Time Password</h2>

                    <p class="message">
                        A sign-in attempt was made to the portfolio admin panel. Use the code below to verify your
                        identity and gain access. This code is valid for <strong
                            style="color: #ffffff; font-weight: 600;">10 minutes</strong>.
                    </p>

                    <div class="otp-box">
                        <span class="otp-label">Verification Code</span>
                        <p class="otp-code">{{otp}}</p>
                        <p class="otp-expiry">Expires in 10 minutes &nbsp;·&nbsp; Do not share this code.</p>
                    </div>

                    <div class="warning-block">
                        <p>
                            If you did not attempt to access the admin panel, you can safely ignore this email.
                            No changes have been made to your account.
                        </p>
                    </div>
                </div>

                <!-- Footer -->
                <div class="footer">
                    <p class="footer-brand">Zeketo Portfolio</p>
                    <p>This is an automated security email &mdash; please do not reply.</p>
                    <p style="margin-top: 12px;">&copy; {{year}} Zeketo. All rights reserved.</p>
                </div>

            </div>
        </div>
    </center>
</body>

</html>
